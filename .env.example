# AI Model Configuration
# Provider should be 'gemini', 'openai', or 'groq'
AI_PROVIDER=gemini

# API Key for Gemini API (get one from https://aistudio.google.com/)
GEMINI_API_KEY=

# API Key for OpenAI API (optional, if AI_PROVIDER=openai)
OPENAI_API_KEY=

# API Key for Groq API (optional, if AI_PROVIDER=groq)
GROQ_API_KEY=

# FastAPI backend configurations
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
